# Segredos referenciados pelo config/deploy.yml (env/secret, registry, builder,
# accessories). NUNCA ponha credenciais cruas aqui — este arquivo é versionado.
# Cada linha puxa da ENV do operador (NOME=$NOME). Antes de `kamal deploy`, tenha
# essas variáveis exportadas no seu shell, ex.:
#
#   set -a; source .env.production; set +a   # .env.production NÃO versionado
#
# ou use um gerenciador de senha (kamal secrets fetch --adapter 1password ...).

# Master key do Rails (decifra credentials.yml.enc) — do arquivo local.
RAILS_MASTER_KEY=$(cat config/master.key)

# Registro de imagens (ghcr.io). Use um Personal Access Token com write:packages.
KAMAL_REGISTRY_USERNAME=$KAMAL_REGISTRY_USERNAME
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Banco (acessório Postgres)
POSTGRES_PASSWORD=$POSTGRES_PASSWORD

# App
APP_HOST=$APP_HOST

# OAuth (RF-AUT)
GOOGLE_CLIENT_ID=$GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$GOOGLE_CLIENT_SECRET
DISCORD_CLIENT_ID=$DISCORD_CLIENT_ID
DISCORD_CLIENT_SECRET=$DISCORD_CLIENT_SECRET

# Discord: webhook de novidades (RF-NOV-11) + bot token para DM (RF-NOT-04)
DISCORD_WEBHOOK_URL=$DISCORD_WEBHOOK_URL
DISCORD_BOT_TOKEN=$DISCORD_BOT_TOKEN

# Web Push VAPID (RF-NOT-02)
VAPID_PUBLIC_KEY=$VAPID_PUBLIC_KEY
VAPID_PRIVATE_KEY=$VAPID_PRIVATE_KEY
VAPID_SUBJECT=$VAPID_SUBJECT

# Mercado Pago (RF-LOJ-12)
MERCADO_PAGO_ACCESS_TOKEN=$MERCADO_PAGO_ACCESS_TOKEN
MERCADO_PAGO_PUBLIC_KEY=$MERCADO_PAGO_PUBLIC_KEY
MERCADO_PAGO_WEBHOOK_SECRET=$MERCADO_PAGO_WEBHOOK_SECRET

# Melhor Envio (RF-LOJ-11) — token + cadastro do remetente (CPF de responsável)
MELHOR_ENVIO_TOKEN=$MELHOR_ENVIO_TOKEN
MELHOR_ENVIO_CEP_ORIGEM=$MELHOR_ENVIO_CEP_ORIGEM
MELHOR_ENVIO_CPF_REMETENTE=$MELHOR_ENVIO_CPF_REMETENTE
MELHOR_ENVIO_NOME_REMETENTE=$MELHOR_ENVIO_NOME_REMETENTE
MELHOR_ENVIO_LOGRADOURO_REMETENTE=$MELHOR_ENVIO_LOGRADOURO_REMETENTE
MELHOR_ENVIO_NUMERO_REMETENTE=$MELHOR_ENVIO_NUMERO_REMETENTE
MELHOR_ENVIO_CIDADE_REMETENTE=$MELHOR_ENVIO_CIDADE_REMETENTE
MELHOR_ENVIO_UF_REMETENTE=$MELHOR_ENVIO_UF_REMETENTE

# E-mail (SMTP) — recuperação de senha do Devise (RF-AUT-04) e notificações
SMTP_ADDRESS=$SMTP_ADDRESS
SMTP_PORT=$SMTP_PORT
SMTP_USERNAME=$SMTP_USERNAME
SMTP_PASSWORD=$SMTP_PASSWORD

# Cloudflare R2 (Active Storage, RNF-13)
R2_ACCESS_KEY_ID=$R2_ACCESS_KEY_ID
R2_SECRET_ACCESS_KEY=$R2_SECRET_ACCESS_KEY
R2_ENDPOINT=$R2_ENDPOINT
R2_BUCKET=$R2_BUCKET
