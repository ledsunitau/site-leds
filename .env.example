# Copie para .env e preencha. O .env é ignorado pelo git — NUNCA commitar credenciais.
# Console Google:  https://console.cloud.google.com/apis/credentials
# Console Discord: https://discord.com/developers/applications

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Webhook do canal de novidades (RF-NOV-11) — Server Settings > Integrations > Webhooks
DISCORD_WEBHOOK_URL=

# DM de notificações via bot (RF-NOT-04) — Bot > Token, na aplicação do Discord
DISCORD_BOT_TOKEN=

# Web Push VAPID (RF-NOT-02). Gere um par com: WebPush.generate_key
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=
